<?xml version="1.0" encoding="utf-8"?>
<modification>
  <name>GT Courier Voucher</name>
  <code>gt_courier_voucher</code>
  <version>3.x</version>
  <author>DanielSusanu</author>
  <link>https://www.danielsusanu.com</link> 

  
  <file path="admin/view/template/sale/order_info.twig">
      
      <operation>
        <search><![CDATA[<div class="page-header">]]></search>
        <add position="before"><![CDATA[         
          <div id="gtCourierVoucher"></div>         
           <script src="view/javascript/vendor/react.production.min.js"></script>
           <script src="view/javascript/vendor/react-dom.production.min.js"></script>
           <script src="view/javascript/vendor/babel.min.js"></script>
           <script src="view/javascript/gt_courier/order_info.js?v=1.1.0"></script> 
        ]]></add>
      </operation>      

      <operation>
        <search><![CDATA[<h1>{{ heading_title }}</h1>]]></search>
        <add position="before"><![CDATA[      
         <div class="pull-right" style="margin-right:5px;">   
           <a href="#" class="btn btn-primary" data-toggle="modal" data-target="#gtCourierVoucherModal">GT Courier Voucher</a>   
         </div>
        ]]></add>
      </operation>   
      
      <operation>
        <search><![CDATA[$('#button-history').on('click', function() {]]></search>
        <add position="before"><![CDATA[         
         var gt_api_token="{{ api_token }}";
        ]]></add>
      </operation>      

  </file>
</modification>
